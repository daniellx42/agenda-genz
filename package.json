{
  "name": "agenda-genz",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "better-auth": "^1.5.4",
      "@prisma/client": "^7.2.0",
      "@tanstack/react-form": "^1.28.0",
      "@better-auth/expo": "^1.5.4",
      "@types/jest": "^30.0.0",
      "jest": "^30.2.0",
      "jest-environment-jsdom": "^30.2.0",
      "ts-node": "^10.9.2",
      "@testing-library/dom": "^10.4.1",
      "@testing-library/jest-dom": "^6.9.1",
      "@testing-library/react": "^16.3.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:app": "turbo -F app dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:studio": "turbo -F @agenda-genz/db db:studio",
    "db:generate": "turbo -F @agenda-genz/db db:generate",
    "db:deploy": "turbo -F @agenda-genz/db db:migrate deploy",
    "db:migrate": "turbo -F @agenda-genz/db db:migrate --",
    "db:reset": "turbo -F @agenda-genz/db db:reset"
  },
  "dependencies": {
    "@agenda-genz/env": "workspace:*",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@agenda-genz/config": "workspace:*",
    "@types/bun": "^1.3.10",
    "turbo": "^2.8.17",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "packageManager": "bun@1.3.10"
}
