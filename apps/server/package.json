{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@elysiajs/cors": "^1.4.1",
    "@agenda-genz/auth": "workspace:*",
    "@agenda-genz/db": "workspace:*",
    "@agenda-genz/env": "workspace:*",
    "@sinclair/typebox": "^0.34.48",
    "better-auth": "^1.5.5",
    "dotenv": "^17.3.1",
    "elysia": "^1.4.27",
    "mercadopago": "^2.12.0"
  },
  "devDependencies": {
    "@bogeychan/elysia-logger": "^0.1.10",
    "@agenda-genz/config": "workspace:*",
    "@types/bun": "^1.3.10",
    "pino-pretty": "^13.1.3",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3"
  }
}
